# Supabase — from your project's Settings → API Keys
# Both are safe to expose to the browser; row-level security protects the data.
# Never put the secret key (sb_secret_… / service_role) here.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Older Supabase projects show a legacy JWT anon key (eyJhb…) instead of a
# publishable key. If that's what your dashboard offers, use this name instead:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
